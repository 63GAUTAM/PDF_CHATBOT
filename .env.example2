# ===================================
# PDF Chatbot Backend Configuration
# ===================================

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/pdf-chatbot
# For MongoDB Atlas (Cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/pdf-chatbot?retryWrites=true&w=majority

# Gemini AI API
GEMINI_API_KEY=your_gemini_api_key_here

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Email Configuration
# For Gmail: Use App Password (not regular password)
# Get it at: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@pdfchatbot.com

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# File Upload Configuration
MAX_FILE_SIZE=52428800  # 50MB in bytes

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000      # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100       # per window

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_VOICE_SUPPORT=false

# Logging Configuration
LOG_LEVEL=info  # debug, info, warn, error
LOG_DIR=./logs

# Database Configuration (Optional Advanced)
MONGODB_POOL_SIZE=10
MONGODB_TIMEOUT=5000

# API Configuration
API_TIMEOUT=30000  # 30 seconds
MAX_REQUEST_SIZE=50mb

# Optional: Sentry or Error Tracking
SENTRY_DSN=

# Optional: Redis (for caching)
# REDIS_URL=redis://localhost:6379

# Optional: S3 or Cloud Storage
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BUCKET_NAME=
